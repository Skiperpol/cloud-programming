RABBITMQ_URL=amqp://guest:guest@localhost:5672
CANDIDATE_QUEUE=candidate.events
PARSER_QUEUE=parser.events
VERIFICATION_QUEUE=verification.events
QUALIFICATION_QUEUE=qualification.events
NOTIFICATION_QUEUE=notification.events
GATEWAY_QUEUE=gateway.events

GATEWAY_DB_URL=postgres://recruitment:recruitment@localhost:5433/gateway_db
CANDIDATE_DB_URL=postgres://recruitment:recruitment@localhost:5434/candidate_db
PARSER_DB_URL=postgres://recruitment:recruitment@localhost:5435/parser_db
BLACKLIST_DB_URL=postgres://recruitment:recruitment@localhost:5436/blacklist_db
QUALIFICATION_DB_URL=postgres://recruitment:recruitment@localhost:5437/qualification_db
NOTIFICATION_DB_URL=postgres://recruitment:recruitment@localhost:5438/notification_db

POSTGRES_PASSWORD=recruitment

# Gateway S3 (upload / download). Credentials optional when using IAM role etc.
AWS_REGION=eu-central-1
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional (temporary credentials)
AWS_SESSION_TOKEN=
# Optional (e.g. LocalStack: http://localhost:4566)
AWS_S3_ENDPOINT=
# Set to true for path-style URLs (common with LocalStack / MinIO)
AWS_S3_FORCE_PATH_STYLE=false
